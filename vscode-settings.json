{
  // =========================================================
  // 1. VISUAL
  // =========================================================
  "editor.fontFamily": "'JetBrains Mono', Consolas, monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 13,
  "editor.lineHeight": 1.6,
  "editor.minimap.enabled": false,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.renderWhitespace": "boundary",
  "editor.guides.bracketPairs": true,
  "workbench.iconTheme": "material-icon-theme",
  "workbench.colorTheme": "Bearded Theme Black & Amethyst",
  "editor.rulers": [80, 100, 120],
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // =========================================================
  //AUTOMAÇÃO
  //=========================================================
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit", // Corrige regras de lint (aspas, const vs let)
    "source.organizeImports": "explicit" // Remove imports não usados e ordena alfabeticamente
  },
  "[java]": {
    "editor.defaultFormatter": "redhat.java",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    }
  },

  // =========================================================
  // 3. TYPESCRIPT & NESTJS
  // =========================================================
  "js/ts.suggest.autoImports": true,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "js/ts.tsserver.experimental.enableProjectDiagnostics": true,
  "js/ts.tsdk.path": "node_modules/typescript/lib",

  // FRONTEND
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact",
    "vue-html": "html"
  },

  // =========================================================
  // 5. FILE EXCLUDES
  // =========================================================
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,

    // Node / Web Excludes
    "**/node_modules": true,
    "**/dist": true, // Pasta de build do NestJS
    "**/build": true, // Pasta de build do React
    "**/.next": true, // Next.js
    "**/coverage": true, // Relatórios de testes

    // Unity / Game Dev Excludes
    // Se abrir a pasta do jogo no VS Code, ele ignorará os assets pesados
    "**/Library": true,
    "**/Temp": true,
    "**/Obj": true,
    "**/Logs": true,
    "**/UserSettings": true,
    "**/*.meta": true, // Arquivos de metadados da Unity
    "**/*.unity": true, // Cenas binárias
    "**/*.mat": true, // Materiais
    "**/*.prefab": true // Prefabs
  },

  // "Watcher Exclude": Impede que o VS Code use CPU monitorando essas pastas
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/Library/**": true,
    "**/Temp/**": true
  },

  // =========================================================
  // 6. TERMINAL & SISTEMA
  // =========================================================
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.fontFamily": "'JetBrains Mono', 'Fira Code', Consolas, monospace",
  "chat.viewSessions.enabled": false,
  "chat.contextUsage.enabled": false,
  "chat.agent.enabled": false,
  "workbench.startupEditor": "none"
}
